# ------------------------------------------------------------------------------
# Deportix Portal — environment variables
# Copy to .env.local for local development.
# ------------------------------------------------------------------------------

# Base URL of the public Deportix API. The portal talks ONLY to this URL — it never
# connects to Firebase directly. No secrets belong in this project.
#   Local:      http://localhost:3000
#   Preview/Prod: https://deportix-api.vercel.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
