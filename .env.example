# ------------------------------------------------------------------------------
# Deportix Portal — environment variables
# Copy to .env.local for local development.
# ------------------------------------------------------------------------------

# Base URL of the public Deportix API. The portal talks ONLY to this URL — it never
# connects to Firebase directly. No secrets belong in this project.
#
# Local (same machine):  http://localhost:3000
# Preview/Prod:          https://deportix-api.vercel.app
#
# LAN access: leave localhost here. In the browser the portal automatically calls the API
# at the same hostname as the UI + NEXT_PUBLIC_API_PORT (e.g. http://192.168.x.x:3000).
# Open the portal as http://<IP-de-tu-Mac>:3001 (not localhost) from other devices.
# Both API and portal dev servers must run with -H 0.0.0.0. Restart after config changes.
# Optional: fix API host if auto-detection fails (hostname only, no protocol/port).
# NEXT_PUBLIC_API_LAN_HOST=192.168.1.42
# Optional: extra HMR origins (comma-separated hostnames/IPs).
# ALLOWED_DEV_ORIGINS=
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# API port when resolving LAN hostname (default 3000). Only used when the base URL is localhost.
NEXT_PUBLIC_API_PORT=3000

# Client fetch timeout in ms (default 15000). Shows an error instead of infinite loading.
# NEXT_PUBLIC_API_FETCH_TIMEOUT_MS=15000
